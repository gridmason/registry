# Gridmason Registry — example environment
#
# Copy to `.env` and adjust. Every variable is optional and falls back to the
# default shown here; docs/config.md is the authoritative per-field reference.
# The values below are the local-development defaults — they target the Postgres
# and MinIO published by compose.yaml, so `npm run dev` works with zero config
# once `docker compose up postgres minio createbuckets` is running.
#
# !! DEVELOPMENT ONLY !!  The credentials in this file are well-known dev
# defaults. NEVER use them in a real deployment — set your own secrets and see
# the "Going to production" section of docs/self-host/install.md.

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
SERVICE_NAME=gridmason-registry
REQUEST_ID_HEADER=x-request-id
SHUTDOWN_TIMEOUT_MS=10000

# This instance's source-qualified registry id. Production sets it to the
# instance's canonical id (e.g. registry.gridmason.dev).
REGISTRY_ID=registry.local

# Request-size bounds (see docs/config.md for the accepted ranges).
HTTP_BODY_LIMIT_BYTES=65536
HTTP_MAX_HEADER_SIZE_BYTES=16384

# --- Identity (OIDC) -------------------------------------------------------
# Publisher registration is bound to an OIDC identity; the issuer is the trust
# anchor. Empty allowlist = no issuer trusted = no publisher can register
# (fail closed), so set at least one issuer before accepting registrations.
# Example (GitHub Actions OIDC):
#   OIDC_ISSUER_ALLOWLIST=https://token.actions.githubusercontent.com
OIDC_ISSUER_ALLOWLIST=
# Required token audience; set it to this registry's id to prevent token replay.
OIDC_AUDIENCE=

# --- Human review lane -----------------------------------------------------
# Comma-separated OIDC identities allowed to submit a review verdict, each in
# the canonical composite form `<url-encoded-issuer> <url-encoded-subject>`.
# Empty = no identity can review (fail closed).
REVIEW_REVIEWER_IDENTITIES=
# Flagship-only self-review waiver. Keep false on a self-host instance so that
# reviewer is always distinct from author.
REVIEW_SELF_REVIEW_WAIVER=false

# --- Countersign + transparency logging ------------------------------------
# PEM PKCS#8 ECDSA P-256 key/cert the registry countersigns approvals with.
# Sourced from a custody-controlled secret — never a reviewer credential. When
# empty, the countersign stage does not mount. Generate a self-signed pair per
# docs/self-host/install.md; a single-line value may \n-escape its newlines.
COUNTERSIGN_PRIVATE_KEY=
COUNTERSIGN_CERTIFICATE=
# Transparency log: `memory` is the zero-config dev default (non-durable);
# production sets `rekor` (the boot guard refuses `memory` under NODE_ENV=production).
TRANSPARENCY_LOG_DRIVER=memory
TRANSPARENCY_LOG_REKOR_URL=https://rekor.sigstore.dev
# TRANSPARENCY_LOG_ORIGIN=   # defaults to REGISTRY_ID
TRANSPARENCY_LOG_ALLOW_MEMORY_IN_PRODUCTION=false

# --- Revocation & kill feed ------------------------------------------------
# Comma-separated OIDC identities allowed to issue a revoke/kill (same form as
# the reviewer roster). Empty = no identity can operate the kill switch.
OPS_OPERATOR_IDENTITIES=
# Feed freshness window in seconds (1–86400); 1 h keeps kills within the online
# propagation bound.
REVOCATION_FEED_TTL_SECONDS=3600

# --- Storage: Postgres -----------------------------------------------------
# DEV ONLY credentials — replace for any real deployment.
DATABASE_URL=postgres://gridmason:gridmason@localhost:5432/gridmason
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000

# --- Storage: object store (S3-compatible; MinIO in dev) -------------------
# DEV ONLY credentials — replace for any real deployment. For real AWS S3, leave
# the endpoint empty (resolve from region) and set OBJECT_STORE_FORCE_PATH_STYLE=false.
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_BUCKET=gridmason-registry
OBJECT_STORE_ACCESS_KEY_ID=gridmason
OBJECT_STORE_SECRET_ACCESS_KEY=gridmason-dev-secret
OBJECT_STORE_FORCE_PATH_STYLE=true
