{
  "name": "@gridmason/registry",
  "version": "0.0.0",
  "private": true,
  "description": "Gridmason Registry — self-hostable federated widget/plugin registry service.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "gridmason-registry": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "policy:render": "tsx scripts/render-policy.ts",
    "policy:check": "tsx scripts/render-policy.ts --check"
  },
  "dependencies": {
    "@gridmason/protocol": "^0.0.2",
    "fastify": "^5.2.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}
